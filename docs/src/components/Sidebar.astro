---
const { currentPath } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const groups = [
	{
		title: "Guide",
		links: [
			{ text: "Getting Started", href: `${base}/getting-started` },
			{ text: "Features", href: `${base}/features` },
			{ text: "Configuration", href: `${base}/configuration` },
			{ text: "TLS Setup", href: `${base}/tls-setup` },
		],
	},
	{
		title: "Usage",
		links: [
			{ text: "Sessions", href: `${base}/sessions` },
			{ text: "Keyboard Controls", href: `${base}/keyboard` },
			{ text: "Command Palette", href: `${base}/command-palette` },
			{ text: "Snippets", href: `${base}/snippets` },
			{ text: "Speech & TTS", href: `${base}/speech` },
			{ text: "Password Vault", href: `${base}/vault` },
		],
	},
	{
		title: "Reference",
		links: [
			{ text: "Themes & Customization", href: `${base}/themes` },
			{ text: "Troubleshooting", href: `${base}/troubleshooting` },
			{ text: "How it works", href: `${base}/how-it-works` },
		],
	},
];
---

<nav class="docs-sidebar" id="sidebar">
	<button class="sidebar-close" id="sidebar-close" aria-label="Close menu">
		&times;
	</button>
	<div class="sidebar-title"><a href={`${base}/getting-started`}>Wormhole</a></div>
	{groups.map((group) => (
		<div class="sidebar-group">
			<div class="sidebar-group-title">{group.title}</div>
			{group.links.map((link) => (
				<a
					class="sidebar-link"
					href={link.href}
					aria-current={currentPath === link.href ? "page" : undefined}
				>
					{link.text}
				</a>
			))}
		</div>
	))}
</nav>
